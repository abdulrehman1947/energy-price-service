# MySQL connection
MYSQL_HOST=127.0.0.1
MYSQL_PORT=3306
MYSQL_USER=root
MYSQL_PASSWORD=root
MYSQL_DATABASE=energy

# External API URLs (energy-charts JSON)
ELECTRICITY_API_URL=https://www.energy-charts.info/charts/price_futures/data/fr/power_year.json
GAS_API_URL=https://www.energy-charts.info/charts/price_futures/data/fr/gas_year.json

# Cron: default every 5 minutes
SYNC_CRON=*/5 * * * *

# Service port
PORT=3000
